FROM php:8.3-apache

# Install system dependencies and ca-certificates
RUN apt-get update && apt-get install -y \
    git \
    unzip \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && update-ca-certificates

# Install PHP extensions needed for the app
RUN docker-php-ext-install pdo pdo_mysql

# Install Composer using a different method to avoid SSL issues
COPY --from=composer:latest /usr/bin/composer /usr/local/bin/composer
RUN chmod +x /usr/local/bin/composer


# Set Apache document root in the default site config
RUN sed -i 's|DocumentRoot /var/www/html|DocumentRoot /var/www/html/www|g' /etc/apache2/sites-available/000-default.conf \
    && sed -i 's|<Directory /var/www/html>|<Directory /var/www/html/www>|g' /etc/apache2/apache2.conf

# Copy app source
COPY . /var/www/html



# Enable Apache mod_rewrite for .htaccess support
RUN a2enmod rewrite



# Ensure temp and cache directories exist and are writable by www-data
RUN mkdir -p /var/www/html/temp/cache && \
    chown -R www-data:www-data /var/www/html/temp && \
    chmod -R 777 /var/www/html/temp

# Set basic permissions for web files
RUN chmod -R o+rX /var/www/html/www

# Expose port 80
EXPOSE 80
